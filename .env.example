# ─────────────────────────────────────────────────────────────────────────────
# Elite PC — Environment Variables
# Copy this file to .env:   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Django
# Generate key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: SQLite by default (no setup needed)
# To use PostgreSQL: change DB_ENGINE=postgresql and fill in fields below
DB_ENGINE=sqlite
# DB_ENGINE=postgresql
# DB_NAME=elitepc_db
# DB_USER=postgres
# DB_PASSWORD=your-strong-password
# DB_HOST=localhost
# DB_PORT=5432

# Redis (optional - only needed for Celery background tasks)
# REDIS_URL=redis://localhost:6379/1
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=

# AI integrations (optional, for PC configurator evaluation)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Shop settings
PC_ASSEMBLY_FEE=500

# Production only
# SECURE_SSL_REDIRECT=False
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
