# ─────────────────────────────────────────────────────────────────────────────
# Elite PC Frontend — Environment Variables
# Copy this file to .env:   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# API base URL
# Development: leave empty — Vite proxy forwards /api to localhost:8000
# Production: set to your backend URL
# VITE_API_BASE_URL=https://your-domain.com/api/v1
